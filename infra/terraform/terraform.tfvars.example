# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit real credentials.

aws_region         = "us-west-2"
instance_type      = "t3.micro"
rds_instance_class = "db.t3.micro"
project_name       = "serviots-task"

# Your public IP — find it at https://checkip.amazonaws.com
# Must be in CIDR notation: x.x.x.x/32 for a single IP
ops_ip_cidr = "YOUR_PUBLIC_IP/32"

# Name of your existing EC2 key pair (created in AWS Console → EC2 → Key Pairs)
key_name = "your-key-pair-name"

# RDS master password — use something strong, store it in a password manager
# This is the only place it needs to be written; Jenkins gets it separately
db_password = "YourStrongPasswordHere!"
